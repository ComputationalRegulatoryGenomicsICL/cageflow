nextflow_process {

    name "Test Process GTF2TXDB"
    script "modules/local/gtf2txdb/main.nf"
    process "GTF2TXDB"

    test("Should run without failures") {

        when {
            params {
                outdir = "tests/results"
            }
            process {
                """
                input[0] = file("${projectDir}/test_data/example.gtf")
                """
            }
        }

        then {
            assert process.success
        }

    }

}
